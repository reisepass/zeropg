{
  "name": "@zeropg/client",
  "version": "0.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "src"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "tsc -p tsconfig.build.json",
    "test": "tsx test/client.test.ts && tsx test/lock-multiprocess.test.ts",
    "test:stress": "tsx test/lock-stress.test.ts"
  },
  "description": "Early experiment in the cheapest possible scale-to-zero Postgres. The unified zeropg client (Track E): one connect(DATABASE_URL) factory and one node-postgres-shaped interface over four engines (in-process PGlite for memory://, file:// with a cross-process lockfile, bucket-backed scale-to-zero zeropg over HTTP, and a graduated postgres:// passthrough). Only the connection string changes from laptop to bucket to always-on server.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reisepass/zeropg.git",
    "directory": "packages/client"
  },
  "keywords": [
    "postgres",
    "pglite",
    "connection-string",
    "scale-to-zero",
    "serverless",
    "node-postgres"
  ],
  "dependencies": {
    "@zeropg/blobstore": "^0.0.1",
    "@zeropg/objectstore-fs": "^0.0.1",
    "@zeropg/server": "^0.0.1"
  },
  "peerDependencies": {
    "@electric-sql/pglite": "*",
    "@electric-sql/pglite-socket": "*",
    "pg": "*"
  },
  "peerDependenciesMeta": {
    "@electric-sql/pglite-socket": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22"
  }
}
