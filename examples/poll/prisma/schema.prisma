// A tiny Rallly/Doodle-style meeting poll, authored in Prisma. This is a REAL
// Prisma app — the point is that an existing Prisma codebase runs on zeropg with
// the proven path: Prisma authors the schema, zeropg's single writer applies the
// generated SQL at boot, and the Prisma client queries over the pglite-socket
// wire via @prisma/adapter-pg (see ORM-ADAPTER-NOTES.md, verified 2026-06-21).
//
// Regenerate the client + migration SQL after editing:
//   DATABASE_URL=postgres://x npx prisma generate --schema examples/poll/prisma/schema.prisma
//   DATABASE_URL=postgres://x npx prisma migrate diff --from-empty \
//     --to-schema examples/poll/prisma/schema.prisma --script > examples/poll/prisma/migrations/0001_init.sql

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Poll {
  id           String        @id @default(cuid())
  title        String
  createdAt    DateTime      @default(now())
  options      Option[]
  participants Participant[]
}

model Option {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label  String
  sort   Int    @default(0)
  votes  Vote[]
}

model Participant {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  votes     Vote[]
}

model Vote {
  id            String      @id @default(cuid())
  optionId      String
  option        Option      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  value         String // 'yes' | 'ifneedbe' | 'no'

  @@unique([optionId, participantId])
}
