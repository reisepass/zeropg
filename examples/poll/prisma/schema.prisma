// A tiny Rallly/Doodle-style meeting poll, authored in Prisma. This is a REAL
// Prisma app — the point is that an existing Prisma codebase runs on zeropg with
// the proven path: Prisma authors the schema, zeropg's single writer applies the
// committed migrations at boot (via @zeropg/cli's migrateDeploy()), and the
// Prisma client queries over the wire via @prisma/adapter-pg (see
// ORM-ADAPTER-NOTES.md, verified 2026-06-21).
//
// Regenerate the client, then author the next migration with the zeropg CLI
// (which needs no external Postgres — it uses a throwaway PGlite shadow):
//   npx prisma generate --schema examples/poll/prisma/schema.prisma
//   cd examples/poll && npx tsx ../../packages/cli/src/zeropg.ts migrate dev --name <name>

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Poll {
  id           String        @id @default(cuid())
  title        String
  createdAt    DateTime      @default(now())
  options      Option[]
  participants Participant[]
}

model Option {
  id     String @id @default(cuid())
  pollId String
  poll   Poll   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  label  String
  sort   Int    @default(0)
  votes  Vote[]
}

model Participant {
  id        String   @id @default(cuid())
  pollId    String
  poll      Poll     @relation(fields: [pollId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime @default(now())
  votes     Vote[]
}

model Vote {
  id            String      @id @default(cuid())
  optionId      String
  option        Option      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  value         String // 'yes' | 'ifneedbe' | 'no'

  @@unique([optionId, participantId])
}
