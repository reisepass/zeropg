generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

model Board {
  id    Int    @id @default(autoincrement())
  name  String
  tasks Task[]
}

model Task {
  id      Int    @id @default(autoincrement())
  boardId Int
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title   String
  status  String @default("todo")
}
