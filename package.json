{
  "name": "zeropg-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm run build -w @zeropg/blobstore && npm run build -w @zeropg/lease && npm run build -w @zeropg/objectstore-fs && npm run build -w @zeropg/server && npm run build -w @zeropg/client",
    "e0": "tsx experiments/e0-primitives.ts",
    "e1": "tsx experiments/e1-lease.ts",
    "e2": "tsx experiments/e2-roundtrip.ts"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "esbuild": "^0.28.0",
    "pg": "^8.21.0",
    "pg-gateway": "^0.3.0-beta.4",
    "playwright": "^1.60.0",
    "prisma": "^7.8.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.5.2",
    "@electric-sql/pglite-socket": "^0.2.2"
  }
}
